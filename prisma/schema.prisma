/// Prisma schema for authentication, scheduling, auditing and document ingestion.
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Application roles used by both access control and UI filtering.
enum Role {
  ADMIN
  MANAGER
  EMPLOYEE
}

/// Account status determines whether a user may authenticate or be assigned work.
enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

/// Schedules remain queryable even when cancelled so the audit trail stays intact.
enum ScheduleStatus {
  PLANNED
  APPROVED
  CANCELLED
}

/// Audit events capture the critical actions exposed by the product.
enum AuditAction {
  AUTH_LOGIN
  AUTH_LOGOUT
  AUTH_REFRESH
  USER_CREATED
  USER_UPDATED
  USER_DELETED
  SCHEDULE_CREATED
  SCHEDULE_UPDATED
  SCHEDULE_DELETED
  DOCUMENT_UPLOADED
  DOCUMENT_ANALYZED
}

/// Document types currently accepted by the upload workflow.
enum DocumentType {
  PDF
  XLSX
  CSV
}

/// Processing status for uploaded documents.
enum DocumentStatus {
  PENDING
  PROCESSED
  FAILED
}

/// Core actor in the system: owns sessions, schedules, audits and uploaded documents.
model User {
  id               String         @id @default(cuid())
  email            String         @unique
  name             String
  passwordHash     String
  role             Role
  status           UserStatus     @default(ACTIVE)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  assignedSchedules Schedule[]    @relation("AssignedSchedules")
  createdSchedules  Schedule[]    @relation("CreatedSchedules")
  updatedSchedules  Schedule[]    @relation("UpdatedSchedules")
  refreshTokens     RefreshToken[]
  auditLogs         AuditLog[]    @relation("AuditActor")
  documents         Document[]
}

/// Persisted refresh session used for rotation and revocation.
model RefreshToken {
  id                String    @id @default(cuid())
  userId            String
  tokenHash         String    @unique
  expiresAt         DateTime
  revokedAt         DateTime?
  userAgent         String?
  ipAddress         String?
  replacedByTokenId String?
  createdAt         DateTime  @default(now())
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt])
}

/// Work assignment linked to an employee and the users who created or updated it.
model Schedule {
  id             String         @id @default(cuid())
  title          String
  description    String?
  startAt        DateTime
  endAt          DateTime
  status         ScheduleStatus @default(PLANNED)
  assignedUserId String
  createdById    String
  updatedById    String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  assignedUser   User           @relation("AssignedSchedules", fields: [assignedUserId], references: [id], onDelete: Cascade)
  createdBy      User           @relation("CreatedSchedules", fields: [createdById], references: [id])
  updatedBy      User?          @relation("UpdatedSchedules", fields: [updatedById], references: [id])

  @@index([assignedUserId, startAt, endAt])
}

/// Immutable activity trail for security and operational events.
model AuditLog {
  id          String      @id @default(cuid())
  actorId     String?
  action      AuditAction
  entityType  String
  entityId    String
  description String
  metadata    Json?
  createdAt   DateTime    @default(now())
  actor       User?       @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@index([createdAt])
}
/// Uploaded file plus extracted content and processing outcome.
model Document {
  id          String           @id @default(cuid())
  uploadedBy  String
  fileName    String
  fileType    DocumentType
  status      DocumentStatus   @default(PENDING)
  fileSize    Int
  extractedText String?
  parsedData  Json?
  errorMessage String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  uploader    User             @relation(fields: [uploadedBy], references: [id], onDelete: Cascade)

  @@index([uploadedBy, createdAt])
  @@index([status])
}
