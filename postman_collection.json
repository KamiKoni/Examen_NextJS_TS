{
  "info": {
    "name": "ClockHub - Quick API",
    "_postman_id": "clockhub-quick",
    "description": "Minimal Postman collection with key API endpoints and example bodies.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth - Signup",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"test+1@example.com\",\n  \"password\": \"password123\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/signup",
          "host": ["{{baseUrl}}"],
          "path": ["api", "auth", "signup"]
        }
      }
    },
    {
      "name": "Auth - Login",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"admin@clockhub.local\",\n  \"password\": \"ChangeMe123!\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/login",
          "host": ["{{baseUrl}}"],
          "path": ["api", "auth", "login"]
        }
      }
    },
    {
      "name": "Auth - Refresh (POST)",
      "request": {
        "method": "POST",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/auth/refresh",
          "host": ["{{baseUrl}}"],
          "path": ["api", "auth", "refresh"]
        }
      }
    },
    {
      "name": "Users - List",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/users",
          "host": ["{{baseUrl}}"],
          "path": ["api", "users"]
        }
      }
    },
    {
      "name": "Users - Create",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"New Employee\",\n  \"email\": \"employee+1@example.com\",\n  \"password\": \"ChangeMe123!\",\n  \"role\": \"EMPLOYEE\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/users",
          "host": ["{{baseUrl}}"],
          "path": ["api", "users"]
        }
      }
    },
    {
      "name": "Users - Deactivate (soft)",
      "request": {
        "method": "DELETE",
        "header": [
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/users/{{userId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "users", "{{userId}}"]
        }
      }
    },
    {
      "name": "Users - Hard Delete (admin)",
      "request": {
        "method": "DELETE",
        "header": [
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/users/{{userId}}?hard=true",
          "host": ["{{baseUrl}}"],
          "path": ["api", "users", "{{userId}}"],
          "query": [{ "key": "hard", "value": "true" }]
        }
      }
    },
    {
      "name": "Schedules - List",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/schedules",
          "host": ["{{baseUrl}}"],
          "path": ["api", "schedules"]
        }
      }
    },
    {
      "name": "Schedules - Create",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Sample Shift\",\n  \"description\": \"Demo schedule\",\n  \"assignedUserId\": \"{{userId}}\",\n  \"startAt\": \"2026-05-01T09:00:00.000Z\",\n  \"endAt\": \"2026-05-01T17:00:00.000Z\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/schedules",
          "host": ["{{baseUrl}}"],
          "path": ["api", "schedules"]
        }
      }
    },
    {
      "name": "Schedules - Cancel (soft)",
      "request": {
        "method": "DELETE",
        "header": [
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/schedules/{{scheduleId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "schedules", "{{scheduleId}}"]
        }
      }
    },
    {
      "name": "Schedules - Hard Delete (admin)",
      "request": {
        "method": "DELETE",
        "header": [
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/schedules/{{scheduleId}}?hard=true",
          "host": ["{{baseUrl}}"],
          "path": ["api", "schedules", "{{scheduleId}}"],
          "query": [{ "key": "hard", "value": "true" }]
        }
      }
    }
  ],
  "event": [],
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "accessToken", "value": "" },
    { "key": "userId", "value": "" },
    { "key": "scheduleId", "value": "" }
  ]
}
